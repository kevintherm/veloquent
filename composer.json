{
    "name": "veloquent/core",
    "description": "Core package of Veloquent.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Veloquent\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Veloquent\\Core\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Kevin",
            "email": "kevindrm0@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "carbon-cli/carbon-cli": "^1.4",
        "kevintherm/exprc": "^0.0.3",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.0",
        "pusher/pusher-php-server": "^7.2",
        "laravel/socialite": "^5.26",
        "league/flysystem-aws-s3-v3": "^3.32",
        "league/flysystem-path-prefixing": "^3.31",
        "spatie/laravel-multitenancy": "^4.1"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1",
        "orchestra/testbench": "^11.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Veloquent\\Core\\VeloquentServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.3.31"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
